generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String              @id @default(uuid())
  email               String              @unique
  password            String
  role                Role                @default(STUDENT)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  refreshToken        String?
  fullName            String?
  name                String?
  usn                 String?             @unique
  department          String?
  collegeName         String?
  subjects            String[]            @default([])
  mentorId            String?
  companyId           String?
  createdAssessments  Assessment[]        @relation("CreatedAssessments")
  assessmentAttempts  AssessmentAttempt[]
  interviewsAsFaculty MockInterview[]     @relation("FacultyInterviews")
  interviewsAsStudent MockInterview[]     @relation("StudentInterviews")
  notifications       Notification[]
  questions           Question[]
  StudentProfile      StudentProfile?
  company             Company?            @relation(fields: [companyId], references: [id])
  mentor              User?               @relation("Mentees", fields: [mentorId], references: [id])
  mentees             User[]              @relation("Mentees")
  assignedAssessments Assessment[]        @relation("AssignedAssessments")
  appliedDrives       PlacementDrive[]    @relation("DriveApplications")
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  type      String   @default("INFO")
  read      Boolean  @default(false)
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Question {
  id           String       @id @default(uuid())
  text         String
  answer       String
  options      Json?
  type         String       @default("MCQ")
  subject      String?
  topic        String?
  difficulty   String?
  isVisible    Boolean      @default(false)
  uploadedById String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  explanation  String?
  uploadedBy   User         @relation(fields: [uploadedById], references: [id])
  assessments  Assessment[] @relation("AssessmentQuestions")
  tags         Tag[]        @relation("QuestionTags")
}

model Assessment {
  id              String              @id @default(uuid())
  title           String
  description     String?
  type            String
  subject         String?
  topic           String?
  scheduledAt     DateTime
  duration        Int
  createdById     String
  resultsReleased Boolean             @default(false)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  createdBy       User                @relation("CreatedAssessments", fields: [createdById], references: [id])
  attempts        AssessmentAttempt[]
  questions       Question[]          @relation("AssessmentQuestions")
  students        User[]              @relation("AssignedAssessments")
}

model AssessmentAttempt {
  id                String     @id @default(uuid())
  score             Float
  correctCount      Int
  totalCount        Int
  timeTaken         Int
  focusLossCount    Int        @default(0)
  answers           Json
  userId            String
  assessmentId      String
  createdAt         DateTime   @default(now())
  questionsSnapshot Json?
  assessment        Assessment @relation(fields: [assessmentId], references: [id])
  user              User       @relation(fields: [userId], references: [id])
}

model Company {
  id             String           @id @default(uuid())
  name           String           @unique
  role           String?
  ctc            String?
  minCgpa        Float?           @default(7.0)
  minReadiness   Float?           @default(70.0)
  minApt         Float?           @default(70.0)
  minCode        Float?           @default(70.0)
  branches       String[]
  requiredSkills String[]
  industry       String?
  tier           String?          @default("Service")
  description    String?
  logoUrl        String?
  website        String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  requests       InboundRequest[]
  drives         PlacementDrive[]
  users          User[]
}

model InboundRequest {
  id             String        @id @default(uuid())
  title          String
  description    String?
  ctc            String?
  minCgpa        Float?
  minReadiness   Float?
  requiredSkills String[]
  status         RequestStatus @default(PENDING)
  companyId      String
  targetCollege  String?
  poDecisionAt   DateTime?
  poFeedback     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  company        Company       @relation(fields: [companyId], references: [id])
}

model PlacementDrive {
  id          String   @id @default(uuid())
  title       String
  description String?
  date        DateTime
  location    String?
  role        String?
  type        String   @default("FULL_TIME")
  status      String   @default("UPCOMING")
  salary      String?
  companyId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id])
  students    User[]   @relation("DriveApplications")
}

model Tag {
  id        String     @id @default(uuid())
  name      String     @unique
  questions Question[] @relation("QuestionTags")
}

model StudentProfile {
  id              String  @id @default(uuid())
  userId          String  @unique
  aptitudeScore   Float?
  codingScore     Float?
  coreScore       Float?
  softSkillsScore Float?
  cgpa            Float?
  attendance      Float?
  branch          String?
  semester        Int?
  readinessScore  Float?
  aiFeedback      String?
  placementStatus String  @default("UNPLACED")
  interviewScore  Float?  @default(0)
  User            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MockInterview {
  id           String             @id @default(uuid())
  title        String
  type         InterviewType      @default(AI)
  mode         InterviewMode      @default(TECHNICAL)
  status       InterviewStatus    @default(SCHEDULED)
  studentId    String
  facultyId    String?
  overallScore Float              @default(0)
  analysis     Json?
  feedback     String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  scheduledAt  DateTime           @default(now())
  messages     InterviewMessage[]
  faculty      User?              @relation("FacultyInterviews", fields: [facultyId], references: [id])
  student      User               @relation("StudentInterviews", fields: [studentId], references: [id])
}

model InterviewMessage {
  id          String        @id @default(uuid())
  interviewId String
  text        String
  createdAt   DateTime      @default(now())
  senderName  String
  senderRole  String
  interview   MockInterview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
}

model TrainingModuleProgress {
  id              String   @id @default(uuid())
  userId          String
  moduleKey       String
  questionsRead   Int      @default(0)
  readQuestionIds String[] @default([])
  completed       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, moduleKey])
}

model TrainingTestResult {
  id           String   @id @default(uuid())
  userId       String
  moduleKey    String
  score        Float
  correctCount Int
  totalCount   Int
  answers      Json
  createdAt    DateTime @default(now())
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InterviewType {
  FACULTY
  AI
}

enum InterviewMode {
  TECHNICAL
  HR
  BEHAVIORAL
}

enum InterviewStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
}

enum Role {
  STUDENT
  FACULTY
  PLACEMENT
  COMPANY
}
